{
  "$schema_note": "Lightweight TIMPush issue router. Keep this file small: route only, no solution body.",
  "version": "2026-07-08",
  "routing_policy": {
    "purpose": "Best-effort candidate routing, not an exhaustive decision tree.",
    "order": [
      "Use high-priority exact error-code or keyword routes first.",
      "Use low-priority generic platform routes when the user gives a broad symptom.",
      "If no route matches, ask fallback.question once and rerun routing with the new facts."
