# 钥匙 1 · 腾讯云 API 密钥（console.tencentcloud.com/cam/capi）
TENCENT_CLOUD_SECRET_ID=
TENCENT_CLOUD_SECRET_KEY=
TENCENT_CLOUD_REGION=ap-guangzhou

# 钥匙 2 · TRTC 应用凭证
# intl = 国际站 console.trtc.io (ap-singapore)
TRTC_REGION=intl
TRTC_SDK_APP_ID=
TRTC_SDK_SECRET_KEY=

# 钥匙 3 · LLM 密钥（OpenAI 兼容协议）
LLM_API_KEY=
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini

PORT=8020
